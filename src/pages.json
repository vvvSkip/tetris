{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^nut-(.*)": "nutui-uniapp/components/$1/$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "俄罗斯方块",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/records/index",
      "style": {
        "navigationBarTitleText": "游戏记录",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/exchangeRecords/index",
      "style": {
        "navigationBarTitleText": "兑换记录",
        "enablePullDownRefresh": false
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "俄罗斯方块",
    "navigationBarBackgroundColor": "#111827",
    "backgroundColor": "#111827"
  }
}
